    "custom_liquid_QbNEtc": {
      "type": "custom-liquid",
      "name": "Custom Liquid",
      "settings": {
        "full_width": true,
        "remove_vertical_spacing": true,
        "remove_horizontal_spacing": false,
        "liquid": "<div class=\"rlv-wirk\">\n  <h2 class=\"rlv-wirk__title\">Trois <span>mécanismes d'action innovants</span></h2>\n  <div class=\"rlv-wirk__grid\">\n    <div class=\"rlv-wirk__features\">\n      <div class=\"rlv-wirk__item\">\n        <div class=\"rlv-wirk__icon\"><img src=\"https://cdn.shopify.com/s/files/1/1001/9337/0459/files/image_177272.png?v=1778686071\" alt=\"Thérapie par la chaleur\"></div>\n        <div class=\"rlv-wirk__text\">\n          <h3>Thérapie par la chaleur</h3>\n          <p>La chaleur dilate les vaisseaux sanguins autour de l'articulation de l'épaule, détend les muscles contractés et améliore la circulation dans les tissus sous-irrigués.</p>\n        </div>\n      </div>\n      <div class=\"rlv-wirk__item\">\n        <div class=\"rlv-wirk__icon\"><img src=\"https://cdn.shopify.com/s/files/1/1001/9337/0459/files/image_177271.png?v=1778686071\" alt=\"Thérapie par massage\"></div>\n        <div class=\"rlv-wirk__text\">\n          <h3>Thérapie par massage</h3>\n          <p>Le massage ciblé libère les tensions musculaires profondes, favorise l'élimination des substances inflammatoires et stimule la régénération des tissus.</p>\n        </div>\n      </div>\n      <div class=\"rlv-wirk__item\">\n        <div class=\"rlv-wirk__icon\"><img src=\"https://cdn.shopify.com/s/files/1/1001/9337/0459/files/image_177273.png?v=1778686071\" alt=\"Compression\"></div>\n        <div class=\"rlv-wirk__text\">\n          <h3>Compression</h3>\n          <p>La pression uniforme maintient la chaleur et le massage de manière constante sur l'articulation concernée — permettant aux deux technologies d'agir précisément là où la douleur apparaît.</p>\n        </div>\n      </div>\n    </div>\n    <div class=\"rlv-wirk__image\">\n      <img src=\"https://cdn.shopify.com/s/files/1/1001/9337/0459/files/Rectangle_22_png.png?v=1778685905\" alt=\"Application de la thérapie sur l'épaule\">\n    </div>\n  </div>\n</div>\n\n<style>\n.rlv-wirk{max-width:1200px;margin:0 auto;padding:60px 20px;font-family:inherit}\n.rlv-wirk__title{text-align:center;font-size:clamp(28px,4vw,42px);font-weight:800;margin:0 0 50px;color:#111;line-height:1.2}\n.rlv-wirk__title span{color:#2aa37a}\n.rlv-wirk__grid{display:grid;grid-template-columns:1fr 1fr;gap:50px;align-items:center}\n.rlv-wirk__item{display:flex;gap:20px;padding:25px 0;align-items:flex-start}\n.rlv-wirk__item+.rlv-wirk__item{border-top:1px solid #e5e5e5}\n.rlv-wirk__icon{flex:0 0 70px}\n.rlv-wirk__icon img{width:70px;height:70px;border-radius:50%;object-fit:cover;display:block}\n.rlv-wirk__text h3{margin:0 0 10px;font-size:20px;font-weight:700;color:#111}\n.rlv-wirk__text p{margin:0;font-size:16px;line-height:1.6;color:#444}\n.rlv-wirk__image img{width:100%;height:auto;border-radius:20px;display:block}\n@media (max-width:768px){\n  .rlv-wirk__grid{grid-template-columns:1fr;gap:30px}\n  .rlv-wirk__image{order:-1}\n}\n</style>",
